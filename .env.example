# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never exposed to client

# AI parsing (email + rate confirmation parser)
ANTHROPIC_API_KEY=sk-ant-...

# Inbound email (Phase 3): forward broker emails to a parsing address,
# e.g. via SendGrid Inbound Parse or Postmark, which POSTs to
# /api/webhooks/inbound-email
INBOUND_EMAIL_WEBHOOK_SECRET=change-me
